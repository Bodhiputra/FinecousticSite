{% schema %}
{
  "name": "Full Width 16:9 Banner",
  "settings": [
    {
      "type": "text",
      "id": "banner_heading",
      "label": "Heading",
      "default": "Your Banner Heading"
    },
    {
      "type": "textarea",
      "id": "banner_description",
      "label": "Description",
      "default": "Add an optional description that appears above the banner."
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image (16:9 recommended)"
    }
  ],
  "presets": [
    {
      "name": "Full Width 16:9 Banner"
    }
  ]
}
{% endschema %}

<section class="fullwidth-16-9-banner">
  
  <!-- Heading -->
  <div class="outer-textbox-wrapper">
    <div class="banner-textbox-wrapper">
    {% if section.settings.banner_heading != blank %}
    <h2 class="banner-heading">{{ section.settings.banner_heading }}</h2>
  {% endif %}

  <!-- Description -->
  {% if section.settings.banner_description != blank %}
    <p class="banner-description">{{ section.settings.banner_description }}</p>
  {% endif %}
  </div>
  </div>

  <div class="outer-banner-wrapper">
    <div class="banner-wrapper">
      {% if section.settings.banner_image %}
        <img 
          src="{{ section.settings.banner_image | image_url: width: 3000 }}" 
          alt="Banner Image"
          class="banner-image"
          loading="lazy"
        >
      {% else %}
        <div class="placeholder">Upload a 16:9 image</div>
      {% endif %}
    </div>
  </div>
</section>

<style>
.outer-textbox-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.banner-textbox-wrapper {
  padding: 0 50px;
   max-width: 90vw;
}

.fullwidth-16-9-banner {
  width: 100%;
  margin: 0;
  padding: 60px 0;
  text-align: center;
}

.fullwidth-16-9-banner .banner-heading {
  font-size: 32px;
  font-weight: 800;
  margin-bottom: 15px;
  line-height: 1.3;
  color: #332F2F;
  width: 100%;
  margin-top: 0;
}

.fullwidth-16-9-banner .banner-description {
  font-size: 18px;
  margin: 0 0 35px;
  color: #808080;
  line-height: 1.6;
  font-weight: 500;
  width: 100%;
}

.outer-banner-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
}

.fullwidth-16-9-banner .banner-wrapper {
  position: relative;
  width: 100%;
  overflow: hidden;
  aspect-ratio: 16 / 9;
  max-width: 90vw;
  padding: 0 50px;
}

.fullwidth-16-9-banner .banner-wrapper img.banner-image {
  width: 100%;
  height: 100%;
  object-fit: fill;
  border-radius: 12px;
}

.fullwidth-16-9-banner .placeholder {
  background: #f2f2f2;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: #888;
}

@media (max-width: 768px) {
  .fullwidth-16-9-banner .banner-wrapper {
    padding: 0 15px;
  }

  .fullwidth-16-9-banner .banner-heading {
    font-size: 26px;
  }

  .fullwidth-16-9-banner .banner-description {
    font-size: 18px;
    margin-bottom: 15px;
  }

  .fullwidth-16-9-banner .banner-wrapper {
  padding: 0 15px;
}
}
</style>
