{% schema %}
{
  "name": "Scrollable Banner Section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Your Section Title"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section Description",
      "default": "Add your description text here."
    }
  ],
  "blocks": [
    {
      "type": "banner_image",
      "name": "Banner Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Upload Banner Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text",
          "default": "Banner image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrollable Banner Section with Dots + Arrows",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<section class="scrollable-banner-section">
  <div class="scroll-container">
    <div class="scroll-container-text">
      <h2 class="section-title">{{ section.settings.title }}</h2>
    <p class="section-description">{{ section.settings.description }}</p>
    </div>

    <div class="scroll-banner-wrapper">
      <div class="scroll-banner" id="scrollBanner">
        <div class="scroll-track">
          {% for block in section.blocks %}
            {% if block.settings.image != blank %}
              <div class="scroll-slide">
                <img 
                  src="{{ block.settings.image | image_url: width: 1400 }}" 
                  alt="{{ block.settings.alt | escape }}" draggable="false">
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <!-- Controls wrapper with border + rounded -->
      <div class="scroll-controls-wrapper">
        <button class="scroll-arrow left" id="scrollLeft">&#10094;</button>
        <div class="scroll-dots" id="scrollDots">
          {% for block in section.blocks %}
            {% if block.settings.image != blank %}
              <span class="dot"></span>
            {% endif %}
          {% endfor %}
        </div>
        <button class="scroll-arrow right" id="scrollRight">&#10095;</button>
      </div>
    </div>
  </div>
</section>

<style>
.scroll-container {
  max-width: 90vw;
  width: 100%;
  padding: 0 5rem;
}

.scrollable-banner-section {
  padding: 60px 0;
  text-align: center;
  background: white;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
}

.section-title {
  font-size: 40px;
  margin-bottom: 1.5rem;
  font-weight: 800;
}

.section-description {
  max-width: 700px;
  margin: 0 auto 2rem auto;
  font-size: 20px;
  color: #808080;
  font-weight: 500;
}

.scroll-banner-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.scroll-banner {
  width: 100%; /* full width */
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  scroll-behavior: smooth;
  cursor: default;
  user-select: none;
}

.scroll-banner::-webkit-scrollbar {
  display: none;
}

.scroll-track {
  display: flex;
  width: 100%;
}

.scroll-slide {
  flex: 0 0 100%; /* each slide takes 100% of banner width */
  scroll-snap-align: start;
  display: flex;
  justify-content: center;
  height: max-content;
}

.scroll-slide img {
  width: 80%; /* image fills the slide */
  height: 80%;
  object-fit: contain;
  border-radius: 12px;
}

/* Controls wrapper with border + rounded */
.scroll-controls-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 3rem;
  gap: 1rem;
  border: 2px solid #000;
  border-radius: 40px;
  padding: 0.5rem 1rem;
  background: black;
}

/* Dots */
.scroll-dots {
  display: flex;
  gap: 0.5rem;
}

.scroll-dots .dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background-color: #FFD300; /* Yellow */
  cursor: pointer;
  opacity: 0.5;
  transition: opacity 0.3s;
}

.scroll-dots .dot.active {
  opacity: 1;
}

/* Arrows */
.scroll-arrow {
  background: #000;
  color: #fff;
  border: none;
  border-radius: 50%;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  font-size: 16px;
  transition: background 0.3s;
}

.scroll-arrow:hover {
  background: #333;
}

/* Tablet */
@media (max-width: 1200px) {
  .scroll-slide img {
    width: 90%;
  }
}

@media (max-width: 990px) {
  .scroll-container {
  max-width: 90vw;
  }
}

@media (max-width: 768px) {
  .scroll-container {
  max-width: 90vw;
  padding: 0 50px;
  }

  .section-title {
    font-size: 30px;
  }

  .section-description {
    font-size: 16px;
  }

  .text-image-split{
    padding: 0;
  }
}

@media (max-width: 768px) {
  .scroll-slide img {
    width: 100%;
  }
}

@media (max-width: 748px) {
  .scroll-container {
  max-width: 100vw;
  }

  .scrollable-banner-section{
  padding: 40px 0;
  }
}

@media (max-width: 480px) {
  .scroll-container {
  padding: 0 40px;;
  }
}

</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const banner = document.getElementById("scrollBanner");
  const dots = document.querySelectorAll("#scrollDots .dot");
  const btnLeft = document.getElementById("scrollLeft");
  const btnRight = document.getElementById("scrollRight");

  function updateDots() {
    const scrollLeft = banner.scrollLeft;
    const bannerWidth = banner.offsetWidth;
    const index = Math.round(scrollLeft / bannerWidth);
    dots.forEach(dot => dot.classList.remove("active"));
    if (dots[index]) dots[index].classList.add("active");
    return index;
  }
  banner.addEventListener("scroll", updateDots);
  updateDots();

  let isDragging = false;
  let startX;
  let scrollStart;

  banner.addEventListener("mousedown", (e) => {
    isDragging = true;
    startX = e.clientX;
    scrollStart = banner.scrollLeft;
    e.preventDefault();
    resetAutoRotate();
  });

  banner.addEventListener("mousemove", (e) => {
    if (!isDragging) return;
    const dx = e.clientX - startX;
    banner.scrollLeft = scrollStart - dx;
  });

  const stopDrag = () => { 
    isDragging = false;
  };
  banner.addEventListener("mouseup", stopDrag);
  banner.addEventListener("mouseleave", stopDrag);

  dots.forEach((dot, index) => {
    dot.addEventListener("click", () => {
      banner.scrollTo({
        left: index * banner.offsetWidth,
        behavior: "smooth"
      });
      resetAutoRotate();
    });
  });

  btnLeft.addEventListener("click", () => {
    banner.scrollBy({ left: -banner.offsetWidth, behavior: "smooth" });
    resetAutoRotate();
  });
  btnRight.addEventListener("click", () => {
    banner.scrollBy({ left: banner.offsetWidth, behavior: "smooth" });
    resetAutoRotate();
  });

  /* --- Auto rotate with cooldown reset --- */
  let autoRotateTimer;

  function startAutoRotate() {
    autoRotateTimer = setInterval(() => {
      const currentIndex = updateDots();
      const nextIndex = (currentIndex + 1) % dots.length;
      banner.scrollTo({
        left: nextIndex * banner.offsetWidth,
        behavior: "smooth"
      });
    }, 5000);
  }

  function resetAutoRotate() {
    clearInterval(autoRotateTimer);
    startAutoRotate();
  }

  startAutoRotate(); // init
});
</script>

