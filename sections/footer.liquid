{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  body:not(.shopify-design-mode) .fc-footer__bottom-links {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 1.5s cubic-bezier(0.22,1,0.36,1), transform 1.5s cubic-bezier(0.22,1,0.36,1);
  }

  @media screen and (max-width: 749px) {
    body:not(.shopify-design-mode) .fc-footer__bottom-links {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }


  #shopify-section-{{ section.id }} {
    isolation: isolate;
    z-index: 2;
  }

  #shopify-section-{{ section.id }} .footer {
    position: relative;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    background-color: transparent !important;
    background-image: none !important;
    overflow: hidden;
    isolation: isolate;
  }

  #shopify-section-{{ section.id }} .fc-footer {
    position: relative;
    z-index: 1;
    height: auto;
    min-height: 0;
    max-height: none;
    overflow: visible;
    padding-top: clamp(12px, 2vw, 20px);
    padding-bottom: clamp(12px, 2vw, 20px);
  }

  #shopify-section-{{ section.id }} .fc-footer__bottom-links {
    position: relative;
    z-index: 1;
    height: auto;
  }

  .section-{{ section.id }}-padding {
    padding-top: 0;
    padding-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .fc-footer {
      height: auto;
      min-height: 0;
      max-height: none;
    }

    #shopify-section-{{ section.id }} .fc-footer__bottom-links {
      --fc-footer-bar-size: clamp(1.35rem, 3.8vw, 1.75rem);
      --fc-footer-bar-gap: clamp(12px, 2.8vw, 18px);
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
      row-gap: 8px;
      height: auto;
      align-content: start;
    }

    #shopify-section-{{ section.id }} .fc-footer__bottom-nav {
      grid-column: 1;
      grid-row: 1;
      justify-self: center;
      justify-content: center;
      width: 100%;
      flex-wrap: wrap;
      row-gap: 8px;
    }

    #shopify-section-{{ section.id }} .fc-footer__bottom-social {
      grid-column: 1;
      grid-row: 2;
      justify-self: center;
      justify-content: center;
    }

    #shopify-section-{{ section.id }} .fc-footer__bottom-copy {
      grid-column: 1;
      grid-row: 3;
      justify-self: center;
      text-align: center;
    }
  }

  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }
  }
{%- endstyle -%}

<footer class="footer color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="fc-footer page-width">
    <div class="fc-footer__bottom-links">
      <nav class="fc-footer__bottom-nav" aria-label="Footer">
        <a href="/pages/policies" class="fc-footer__bottom-link">Policies</a>
        <a href="/pages/download-page" class="fc-footer__bottom-link">Downloads &amp; Guides</a>
        <a href="/pages/about-us" class="fc-footer__bottom-link">About Us</a>
        <a href="/pages/support" class="fc-footer__bottom-link">Support</a>
      </nav>
      <span class="fc-footer__bottom-copy">&copy; Finecoustic {{ 'now' | date: '%Y' }}</span>
      {%- render 'fc-social-icons' -%}
    </div>
  </div>
</footer>

<script>
  (function () {
    if (typeof Shopify !== 'undefined' && Shopify.designMode) return;
    if (window.matchMedia('(max-width: 749px)').matches) return;

    var footer = document.querySelector('footer.footer');
    if (!footer) return;

    var bottomLinks = footer.querySelector('.fc-footer__bottom-links');
    if (!bottomLinks) return;

    var revealed = false;

    function reveal(baseDelay) {
      if (revealed) return;
      revealed = true;
      setTimeout(function () {
        bottomLinks.style.opacity = '1';
        bottomLinks.style.transform = 'translateY(0)';
      }, baseDelay);
    }

    function isInView() {
      var r = footer.getBoundingClientRect();
      return r.top < window.innerHeight && r.bottom > 0;
    }

    if (!('IntersectionObserver' in window)) {
      reveal(0);
      return;
    }

    var io = new IntersectionObserver(function (entries) {
      if (!entries[0].isIntersecting || revealed) return;
      reveal(0);
      io.disconnect();
    }, { threshold: 0 });
    io.observe(footer);

    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        if (!revealed && isInView()) reveal(400);
      });
    });
    window.addEventListener('load', function () {
      if (!revealed && isInView()) reveal(400);
    });
  })();
</script>

