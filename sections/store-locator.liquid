{%- style -%}

/* ── HEADER ── */
.fc-collection-header {
  padding: clamp(10px, 1.5vw, 16px) clamp(12px, 2vw, 24px);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.fc-sl-title-viewport {
  flex: 1;
  min-width: 0;
  max-width: min(700px, calc(100vw - 40px));
  display: flex;
  align-items: center;
  justify-content: center;
}
.fc-sl-title {
  font-family: var(--fc-font);
  font-size: clamp(20px, 5.5vw, 48px);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: #ffffff;
  white-space: nowrap;
}

/* ── SEARCH ── */
.fc-locator-search-row {
  max-width: 1280px;
  margin: 0 auto;
  padding: clamp(8px, 1.2vw, 14px) clamp(24px, 5vw, 64px) clamp(20px, 2.5vw, 32px);
  display: flex;
  justify-content: center;
}
.fc-locator-search-wrap {
  position: relative;
  width: clamp(160px, 22vw, 280px);
}
.fc-locator-search {
  font-family: var(--fc-font);
  font-size: 12px;
  font-weight: 700;
  color: #ffffff;
  background: transparent;
  border: none;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  padding: 10px 24px 10px 4px;
  width: 100%;
  outline: none;
  letter-spacing: -0.01em;
  transition: border-color 0.2s;
  -webkit-appearance: none;
}
.fc-locator-search::-webkit-search-cancel-button,
.fc-locator-search::-webkit-search-decoration { -webkit-appearance: none; appearance: none; }
.fc-locator-search::placeholder { color: rgba(255,255,255,0.18); }
.fc-locator-search-icon {
  position: absolute;
  right: 0; top: 50%;
  transform: translateY(-50%);
  color: rgba(255,255,255,0.18);
  pointer-events: none;
  width: 12px; height: 12px;
}

/* ── GRID ── */
.fc-locator-body {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 clamp(24px, 5vw, 64px);
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: clamp(16px, 2.5vw, 32px);
}

/* ── CARD ── */
.fc-locator-card {
  display: flex;
  flex-direction: column;
  gap: 5px;
  background: #111111;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: 12px;
  padding: 24px 26px 26px;
  text-decoration: none;
  transition: transform 0.3s ease, border-color 0.3s ease;
  box-sizing: border-box;
}
.fc-locator-card:hover {
  transform: translateY(-4px);
  border-color: rgba(255,255,255,0.16);
}
.fc-locator-card--tbd {
  opacity: 0.4;
  pointer-events: none;
}

.fc-locator-card-country {
  font-family: var(--fc-font);
  font-size: 11px;
  font-weight: 700;
  color: var(--fc-yellow);
  letter-spacing: -0.01em;
  margin: 0 0 4px;
  line-height: 1;
}
.fc-locator-card-name {
  font-family: var(--fc-font);
  font-size: 15px;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.01em;
  line-height: 1.25;
  margin: 0;
}
.fc-locator-card-ig {
  font-family: var(--fc-font);
  font-size: 12px;
  font-weight: 700;
  color: rgba(255,255,255,0.38);
  letter-spacing: -0.01em;
  display: inline-flex;
  align-items: center;
  gap: 3px;
  align-self: flex-start;
  border-bottom: 1px solid transparent;
  padding-bottom: 1px;
  margin-top: 6px;
  transition: color 0.2s ease, border-color 0.2s ease;
}
.fc-locator-card:hover .fc-locator-card-ig {
  color: var(--fc-yellow);
  border-color: rgba(255,211,0,0.4);
}
.fc-locator-card-ig-arrow {
  display: inline-block;
  transition: transform 0.15s;
}
.fc-locator-card:hover .fc-locator-card-ig-arrow { transform: translate(2px, -2px); }

.fc-locator-card-tbd {
  font-family: var(--fc-font);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: rgba(255,255,255,0.25);
  margin-top: 4px;
}

/* ── NO RESULTS ── */
.fc-locator-empty {
  max-width: 1280px;
  margin: 0 auto;
  padding: clamp(40px, 6vw, 64px) clamp(24px, 5vw, 64px);
  display: none;
}
.fc-locator-empty.visible { display: block; }
.fc-locator-empty-label {
  font-family: var(--fc-font);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.18);
  margin: 0 0 8px;
}
.fc-locator-empty-query {
  font-family: var(--fc-font);
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 700;
  color: rgba(255,255,255,0.05);
  letter-spacing: -0.04em;
  margin: 0;
}

/* ── FOOTER CTA ── */
.fc-locator-footnote {
  max-width: 1280px;
  margin: clamp(16px, 2.5vw, 28px) auto 0;
  padding: 14px clamp(24px, 5vw, 64px) clamp(48px, 6vw, 80px);
  text-align: right;
}
.fc-locator-footnote-cta {
  font-family: var(--fc-font);
  font-size: 11px;
  font-weight: 700;
  color: var(--fc-yellow);
  text-decoration: none;
  letter-spacing: -0.01em;
  border-bottom: 1px solid rgba(255,211,0,0.22);
  padding-bottom: 1px;
  transition: border-color 0.2s;
}
.fc-locator-footnote-cta:hover { border-color: var(--fc-yellow); }

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .fc-locator-body { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 600px) {
  .fc-locator-body { grid-template-columns: repeat(2, 1fr); gap: 14px; }
}
@media (max-width: 380px) {
  .fc-locator-body { grid-template-columns: 1fr; }
}

{%- endstyle -%}

