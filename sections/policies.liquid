{%- style -%}

/* ── CAROUSEL HEADER ── */
.fc-collection-header {
  padding: clamp(10px, 1.5vw, 16px) clamp(12px, 2vw, 24px);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2px;
  overflow: hidden;
}
.fc-title-viewport {
  flex: 1;
  min-width: 0;
  max-width: min(700px, calc(100vw - 40px));
  overflow: hidden;
  -webkit-mask-image: linear-gradient(to right, transparent 0%, black 20%, black 80%, transparent 100%);
  mask-image: linear-gradient(to right, transparent 0%, black 20%, black 80%, transparent 100%);
  cursor: grab;
}
.fc-title-viewport:active { cursor: grabbing; }
.fc-title-track {
  display: flex;
  align-items: center;
}
.fc-title-item {
  flex-shrink: 0;
  min-width: clamp(100px, 14vw, 200px);
  text-align: center;
  padding: 0 clamp(6px, 1.5vw, 12px);
  font-family: 'Alte Haas Grotesk', sans-serif;
  font-size: clamp(20px, 5.5vw, 48px);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: rgba(255,255,255,0.18);
  white-space: nowrap;
  transition: color 0.4s ease, transform 0.4s ease;
  transform: scale(0.72);
  transform-origin: center;
  user-select: none;
}
.fc-title-item.fc-title-active {
  color: #ffffff;
  transform: scale(1);
  cursor: default;
}
.fc-title-item:not(.fc-title-active) { cursor: pointer; }

@keyframes fc-arrow-prev {
  0%, 100% { transform: translateX(0); }
  50%       { transform: translateX(-4px); }
}
@keyframes fc-arrow-next {
  0%, 100% { transform: translateX(0); }
  50%       { transform: translateX(4px); }
}
.fc-collection-header__arrow {
  background: transparent;
  border: none;
  color: rgba(255,255,255,0.35);
  font-size: clamp(18px, 3vw, 30px);
  cursor: pointer;
  padding: 0 8px;
  line-height: 1;
  transition: color 0.15s;
  flex-shrink: 0;
  z-index: 1;
}
.fc-filter-nav__prev { animation: fc-arrow-prev 2.5s ease-in-out infinite; }
.fc-filter-nav__next { animation: fc-arrow-next 2.5s ease-in-out infinite; }
@media (hover: hover) {
  .fc-collection-header__arrow:hover { color: #FFD300; }
}

/* ── POLICY CONTENT ── */
.fc-policy-wrap {
  max-width: 780px;
  margin: 0 auto;
  padding: 12px clamp(16px, 4vw, 40px) 0;
}

.fc-policy-panel { display: none; }
.fc-policy-panel.fc-pol-active {
  display: block;
  animation: fc-pol-in 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
}
@keyframes fc-pol-in {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Prose */
.fc-policy-panel h1,
.fc-policy-panel h2,
.fc-policy-panel h3,
.fc-policy-panel h4 {
  font-family: 'Alte Haas Grotesk', sans-serif;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.02em;
  margin: 40px 0 12px;
  line-height: 1.2;
}
.fc-policy-panel h1 { font-size: clamp(28px, 4vw, 42px); margin-top: 0; }
.fc-policy-panel h2 { font-size: clamp(20px, 2.5vw, 28px); }
.fc-policy-panel h3 { font-size: clamp(16px, 2vw, 20px); color: rgba(255,255,255,0.85); }

.fc-policy-panel p {
  font-family: 'Alte Haas Grotesk', sans-serif;
  font-size: clamp(14px, 1.2vw, 16px);
  color: rgba(255,255,255,0.65);
  line-height: 1.75;
  margin-bottom: 20px;
  letter-spacing: -0.01em;
}
.fc-policy-panel ul,
.fc-policy-panel ol {
  font-family: 'Alte Haas Grotesk', sans-serif;
  font-size: clamp(14px, 1.2vw, 16px);
  color: rgba(255,255,255,0.65);
  line-height: 1.75;
  margin-bottom: 20px;
  padding-left: 22px;
}
.fc-policy-panel li { margin-bottom: 8px; }
.fc-policy-panel a {
  color: #FFD300;
  text-decoration-color: rgba(255,211,0,0.4);
  text-underline-offset: 3px;
  transition: text-decoration-color 0.2s;
}
.fc-policy-panel a:hover { text-decoration-color: #FFD300; }
.fc-policy-panel strong { color: rgba(255,255,255,0.9); }
.fc-policy-panel hr {
  border: none;
  border-top: 1px solid rgba(255,255,255,0.08);
  margin: 40px 0;
}

.fc-policy-eyebrow {
  font-family: 'Alte Haas Grotesk', sans-serif;
  font-size: 11px;
  font-weight: 700;
  color: #FFD300;
  letter-spacing: -0.01em;
  margin: 0 0 32px;
  text-transform: uppercase;
}

{%- endstyle -%}

<div class="fc-collection-header">
  <button class="fc-collection-header__arrow fc-filter-nav__prev" type="button">&#171;</button>
  <div class="fc-title-viewport" id="fc-pol-viewport">
    <div class="fc-title-track" id="fc-pol-track">
      <span class="fc-title-item">Terms &amp; Conditions</span>
      <span class="fc-title-item fc-title-active">Privacy Policy</span>
      <span class="fc-title-item">Shipping Policy</span>
      <span class="fc-title-item">Return &amp; Refund Policy</span>
      <span class="fc-title-item">Terms &amp; Conditions</span>
      <span class="fc-title-item">Privacy Policy</span>
    </div>
  </div>
  <button class="fc-collection-header__arrow fc-filter-nav__next" type="button">&#187;</button>
</div>

<div class="fc-policy-wrap">

  <div class="fc-policy-panel" id="fc-pol-privacy" data-policy="privacy-policy">
    {%- if shop.privacy_policy.body != blank -%}
      {{ shop.privacy_policy.body }}
    {%- else -%}
      <p class="fc-policy-eyebrow">Legal</p>
      <h1>Privacy Policy</h1>
      <p>No privacy policy has been configured yet.</p>
    {%- endif -%}
  </div>

  <div class="fc-policy-panel" id="fc-pol-shipping" data-policy="shipping-policy">
    {%- if shop.shipping_policy.body != blank -%}
      {{ shop.shipping_policy.body }}
    {%- else -%}
      <p>No shipping policy has been configured yet.</p>
    {%- endif -%}
  </div>

  <div class="fc-policy-panel" id="fc-pol-refund" data-policy="refund-policy">
    {%- if shop.refund_policy.body != blank -%}
      {{ shop.refund_policy.body }}
    {%- else -%}
      <p>No refund policy has been configured yet.</p>
    {%- endif -%}
  </div>

  <div class="fc-policy-panel" id="fc-pol-terms" data-policy="terms-and-conditions">
    {%- if shop.terms_of_service.body != blank -%}
      {{ shop.terms_of_service.body }}
    {%- else -%}
      <p class="fc-policy-eyebrow">Legal</p>
      <h1>Terms &amp; Conditions</h1>
      <p>No terms of service has been configured yet.</p>
    {%- endif -%}
  </div>

</div>

<script>
(function () {

  const POLICIES = [
    { key: 'privacy-policy',       id: 'fc-pol-privacy'  },
    { key: 'shipping-policy',      id: 'fc-pol-shipping' },
    { key: 'refund-policy',        id: 'fc-pol-refund'   },
    { key: 'terms-and-conditions', id: 'fc-pol-terms'    },
  ];
  const N = POLICIES.length; // 4

  let polIdx  = 0;
  let domIdx  = 1;
  let sliding = false;

  let track, viewport, prevBtn, nextBtn;

  function getItems() { return Array.from(track.querySelectorAll('.fc-title-item')); }

  function getCurrentTx() {
    const t = window.getComputedStyle(track).transform;
    if (!t || t === 'none') return 0;
    const m = t.match(/matrix\([^,]+,[^,]+,[^,]+,[^,]+,([^,]+),/);
    return m ? parseFloat(m[1]) : 0;
  }

  function offsetForDom(di) {
    const items   = getItems();
    const item    = items[di];
    if (!item || !viewport) return 0;
    const vpRect   = viewport.getBoundingClientRect();
    const itemRect = item.getBoundingClientRect();
    const tx       = getCurrentTx();
    return tx + (vpRect.left + vpRect.width / 2) - (itemRect.left + itemRect.width / 2);
  }

  function snapToDom(di) {
    track.style.transition = 'none';
    track.style.transform  = `translateX(${offsetForDom(di)}px)`;
    track.getBoundingClientRect();
  }

  function slideToDom(di, onEnd) {
    track.style.transition = 'transform 0.45s cubic-bezier(0.22, 1, 0.36, 1)';
    track.style.transform  = `translateX(${offsetForDom(di)}px)`;
    track.addEventListener('transitionend', function h() {
      track.removeEventListener('transitionend', h);
      if (onEnd) onEnd();
      sliding = false;
    }, { once: true });
  }

  function applyPolicy(key) {
    document.querySelectorAll('.fc-policy-panel').forEach(panel => {
      panel.classList.remove('fc-pol-active');
      if (panel.dataset.policy === key) panel.classList.add('fc-pol-active');
    });
    const url = new URL(window.location.href);
    if (key === 'privacy-policy') {
      url.searchParams.delete('policy');
    } else {
      url.searchParams.set('policy', key);
    }
    history.pushState(null, '', url.toString());
  }

  function slideByDir(dir) {
    if (sliding) return;
    sliding = true;
    const targetDom = domIdx + dir;
    const items = getItems();

    items.forEach((el, i) => el.classList.toggle('fc-title-active', i === targetDom));
    polIdx = targetDom === 0 ? N - 1 : targetDom === N + 1 ? 0 : targetDom - 1;

    slideToDom(targetDom, () => {
      if (targetDom === 0 || targetDom === N + 1) {
        domIdx = targetDom === 0 ? N : 1;
        track.style.opacity = '0';
        getItems().forEach(el => { el.style.transition = 'none'; });
        snapToDom(domIdx);
        getItems().forEach((el, i) => el.classList.toggle('fc-title-active', i === domIdx));
        track.getBoundingClientRect();
        requestAnimationFrame(() => {
          getItems().forEach(el => { el.style.transition = ''; });
          track.style.opacity = '1';
        });
      } else {
        domIdx = targetDom;
      }
    });

    applyPolicy(POLICIES[polIdx].key);
  }

  function attachCarouselClicks() {
    track.addEventListener('click', e => {
      const item = e.target.closest('.fc-title-item');
      if (!item) return;
      const clickedDomIdx = getItems().indexOf(item);
      if (clickedDomIdx === domIdx) return;
      slideByDir(clickedDomIdx > domIdx ? 1 : -1);
    });
  }

  function init() {
    track    = document.getElementById('fc-pol-track');
    viewport = document.getElementById('fc-pol-viewport');
    prevBtn  = document.querySelector('.fc-filter-nav__prev');
    nextBtn  = document.querySelector('.fc-filter-nav__next');

    if (!track) return;

    polIdx  = 0;
    domIdx  = 1;
    sliding = false;

    getItems().forEach((el, i) => el.classList.toggle('fc-title-active', i === 1));
    attachCarouselClicks();

    track.style.opacity = '0';

    requestAnimationFrame(() => {
      const urlPolicy    = new URLSearchParams(window.location.search).get('policy');
      const urlMatchIdx  = urlPolicy ? POLICIES.findIndex(p => p.key === urlPolicy) : -1;

      if (urlMatchIdx > 0) {
        polIdx = urlMatchIdx;
        domIdx = urlMatchIdx + 1;
        getItems().forEach((el, i) => el.classList.toggle('fc-title-active', i === domIdx));
        snapToDom(domIdx);
        applyPolicy(POLICIES[polIdx].key);
      } else {
        polIdx = 0;
        domIdx = 1;
        snapToDom(1);
        applyPolicy('privacy-policy');
      }

      track.style.opacity = '1';
    });

    if (prevBtn) prevBtn.addEventListener('click', () => slideByDir(-1));
    if (nextBtn) nextBtn.addEventListener('click', () => slideByDir(+1));

    let touchX = 0;
    if (viewport) {
      viewport.addEventListener('touchstart', e => { touchX = e.touches[0].clientX; }, { passive: true });
      viewport.addEventListener('touchend', e => {
        const dx = e.changedTouches[0].clientX - touchX;
        if (Math.abs(dx) > 40) slideByDir(dx < 0 ? 1 : -1);
      }, { passive: true });
    }

    let resizing = false;
    window.addEventListener('resize', () => {
      if (resizing) return;
      resizing = true;
      requestAnimationFrame(() => {
        if (track) {
          track.style.transition = 'none';
          track.style.transform  = `translateX(${offsetForDom(domIdx)}px)`;
          track.getBoundingClientRect();
        }
        resizing = false;
      });
    });
  }

  init();
  document.addEventListener('shopify:section:load', init);

  (function titleCaseTerms() {
    const panel = document.getElementById('fc-pol-terms');
    if (!panel) return;
    panel.querySelectorAll('h1, h2, h3, h4').forEach(el => {
      el.textContent = el.textContent.replace(/\S+/g, w =>
        w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()
      );
    });
  })();

})();
</script>

{% schema %}
{
  "name": "Policies",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
