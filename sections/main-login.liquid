{{ 'customer.css' | asset_url | stylesheet_tag }}

{%- style -%}

/* ── PAGE ── */
.fc-login-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: clamp(48px, 8vw, 80px) 20px;
  box-sizing: border-box;
  background-image: url('{{ 'FinecouBG.webp' | asset_url }}');
  background-size: cover;
  background-position: center top;
  background-repeat: no-repeat;
  background-attachment: fixed;
}

/* ── CARD ── */
.fc-login-card {
  width: 100%;
  max-width: 420px;
  background: rgba(0, 0, 0, 0.42);
  backdrop-filter: blur(28px);
  -webkit-backdrop-filter: blur(28px);
  border: 1px solid rgba(255, 255, 255, 0.07);
  padding: clamp(36px, 7vw, 56px) clamp(28px, 6vw, 48px);
  box-sizing: border-box;
}

/* ── LOGO ── */
.fc-login-logo {
  display: flex;
  justify-content: center;
  margin-bottom: 32px;
}

.fc-login-logo img {
  height: 32px;
  width: auto;
  object-fit: contain;
}

/* ── HEADINGS ── */
.fc-login-heading {
  font-family: var(--fc-font);
  font-size: clamp(30px, 5vw, 40px);
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.025em;
  line-height: 1.05;
  margin: 0 0 8px;
  text-align: center;
}

.fc-login-sub {
  font-family: var(--fc-font);
  font-size: 14px;
  color: rgba(255, 255, 255, 0.42);
  text-align: center;
  margin: 0 0 28px;
  line-height: 1.55;
}

/* ── INPUT FIELDS ── */
.fc-field {
  margin-bottom: 12px;
}

.fc-field input {
  width: 100%;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.12);
  color: #ffffff;
  font-family: var(--fc-font);
  font-size: 15px;
  padding: 14px 16px;
  outline: none;
  border-radius: 0;
  -webkit-appearance: none;
  transition: border-color 0.2s ease;
}

.fc-field input::placeholder {
  color: rgba(255, 255, 255, 0.28);
}

.fc-field input:focus {
  border-color: rgba(255, 255, 255, 0.38);
}

.fc-field input[aria-invalid="true"] {
  border-color: rgba(255, 80, 80, 0.55);
}

/* ── BUTTONS ── */
.fc-btn {
  display: block;
  width: 100%;
  font-family: var(--fc-font);
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  border: none;
  padding: 15px;
  cursor: pointer;
  transition: opacity 0.15s ease;
  box-sizing: border-box;
}

.fc-btn--primary {
  background: var(--fc-yellow);
  color: #000000;
  margin-top: 22px;
}

.fc-btn--primary:hover { opacity: 0.85; }

.fc-btn--ghost {
  background: transparent;
  color: rgba(255, 255, 255, 0.55);
  border: 1px solid rgba(255, 255, 255, 0.13);
  margin-top: 10px;
}

.fc-btn--ghost:hover {
  border-color: rgba(255, 255, 255, 0.32);
  color: #ffffff;
  opacity: 1;
}

/* ── LINK ROW ── */
.fc-link-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 14px;
}

.fc-link-row--center { justify-content: center; }

.fc-link {
  font-family: var(--fc-font);
  font-size: 13px;
  color: rgba(255, 255, 255, 0.42);
  text-decoration: none;
  display: inline;
  transition: color 0.15s ease;
}

.fc-link:hover { color: #ffffff; }

/* ── MESSAGES ── */
.fc-form-msg {
  font-family: var(--fc-font);
  font-size: 12px;
  display: block;
  margin-top: 10px;
  padding: 10px 12px;
  line-height: 1.5;
}

.fc-form-msg--error {
  color: #ff8a8a;
  background: rgba(255, 80, 80, 0.08);
  border: 1px solid rgba(255, 80, 80, 0.18);
}

.fc-form-msg--success {
  color: #7dffb0;
  background: rgba(100, 255, 150, 0.07);
  border: 1px solid rgba(100, 255, 150, 0.14);
}

.fc-error-block {
  font-family: var(--fc-font);
  font-size: 13px;
  color: #ff8a8a;
  padding: 12px 14px;
  background: rgba(255, 80, 80, 0.07);
  border: 1px solid rgba(255, 80, 80, 0.16);
  margin-bottom: 16px;
  line-height: 1.5;
}

/* ── DIVIDER ── */
.fc-divider {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 20px 0;
}

.fc-divider::before,
.fc-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(255, 255, 255, 0.07);
}

.fc-divider span {
  font-family: var(--fc-font);
  font-size: 11px;
  color: rgba(255, 255, 255, 0.22);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

/* ── SEPARATOR ── */
.fc-sep {
  height: 1px;
  background: rgba(255, 255, 255, 0.06);
  margin: 28px 0 22px;
}

/* ── TOGGLE MECHANISM ──
   Anchor h1s are sr-only; sibling divs are toggled by customer.css :target rules.
   We override to keep h1s invisible even when :target fires. */
.customer.login { max-width: none; padding: 0; margin: 0; }

#recover,
#login {
  position: absolute !important;
  width: 1px !important;
  height: 1px !important;
  overflow: hidden !important;
  clip: rect(0 0 0 0) !important;
  white-space: nowrap !important;
  margin: -1px !important;
  padding: 0 !important;
  border: 0 !important;
}

/* customer.css hides #recover + div by default — keep that */
/* customer.css shows #recover + div on :target — keep that */
/* customer.css hides #login + div on #recover:target — keep that */

/* ── SHOP LOGIN BUTTON ── */
.fc-login-card .shop-login-button {
  width: 100%;
}

{%- endstyle -%}

{%- if section.settings.enable_shop_login_button == false -%}
  {%- assign hide_shop_login_button = true -%}
{%- endif -%}

<div class="customer login">
  <div class="fc-login-page">
    <div class="fc-login-card">

      <div class="fc-login-logo">
        <img src="{{ 'FinecousticSmall.png' | asset_url }}" alt="Finecoustic" width="32" height="32">
      </div>

      {%- comment -%} ── RECOVER PASSWORD (hidden by default, shown via #recover hash) ── {%- endcomment -%}
      <h1 id="recover" tabindex="-1">{{ 'customer.recover_password.title' | t }}</h1>
      <div>
        <p class="fc-login-heading">Forgot your<br>password?</p>
        <p class="fc-login-sub">{{ 'customer.recover_password.subtext' | t }}</p>

        {%- form 'recover_customer_password' -%}
          {% assign recover_success = form.posted_successfully? %}

          {%- if form.errors -%}
            <small class="fc-form-msg fc-form-msg--error" id="RecoverEmail-email-error">
              {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
            </small>
          {%- endif -%}

          <div class="fc-field">
            <input
              type="email"
              value=""
              name="email"
              id="RecoverEmail"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {% if form.errors %}aria-invalid="true" aria-describedby="RecoverEmail-email-error" autofocus{% endif %}
              placeholder="{{ 'customer.login_page.email' | t }}"
            >
          </div>

          <button type="submit" class="fc-btn fc-btn--primary">
            {{ 'customer.login_page.submit' | t }}
          </button>
          <a href="#login" class="fc-link" style="display:block;text-align:center;margin-top:14px;">
            {{ 'customer.login_page.cancel' | t }}
          </a>
        {%- endform -%}
      </div>

      {%- comment -%} ── LOGIN (visible by default) ── {%- endcomment -%}
      <h1 id="login" tabindex="-1">{{ 'customer.login_page.title' | t }}</h1>
      <div>
        <p class="fc-login-heading">Welcome back.</p>
        <p class="fc-login-sub">Sign in to your Finecoustic account.</p>

        {%- if recover_success == true -%}
          <p class="fc-form-msg fc-form-msg--success" tabindex="-1" autofocus>
            {{- 'customer.recover_password.success' | t }}
          </p>
        {%- endif -%}

        {%- form 'customer_login', novalidate: 'novalidate' -%}
          {%- if form.errors -%}
            <div class="fc-error-block">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          {%- if shop.features.login_with_shop_classic_customer_accounts? -%}
            <section name="sign-in-with-shop-provider">
              {{ shop | login_button: hide_button: hide_shop_login_button }}
              {%- unless hide_shop_login_button -%}
                <div class="fc-divider"><span>{{ 'customer.login_page.alternate_provider_separator' | t }}</span></div>
              {%- endunless -%}
            </section>
          {%- endif -%}

          <div class="fc-field">
            <input
              type="email"
              name="customer[email]"
              id="CustomerEmail"
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              {% if form.errors contains 'form' %}aria-invalid="true"{% endif %}
              placeholder="{{ 'customer.login_page.email' | t }}"
            >
          </div>

          {%- if form.password_needed -%}
            <div class="fc-field">
              <input
                type="password"
                value=""
                name="customer[password]"
                id="CustomerPassword"
                autocomplete="current-password"
                {% if form.errors contains 'form' %}aria-invalid="true"{% endif %}
                placeholder="{{ 'customer.login_page.password' | t }}"
              >
            </div>
          {%- endif -%}

          <button type="submit" class="fc-btn fc-btn--primary">
            {{ 'customer.login_page.sign_in' | t }}
          </button>

          <div class="fc-link-row" style="margin-top:16px;">
            {%- if form.password_needed -%}
              <a href="#recover" class="fc-link">{{ 'customer.login_page.forgot_password' | t }}</a>
            {%- else -%}
              <span></span>
            {%- endif -%}
            <a href="{{ routes.account_register_url }}" class="fc-link">{{ 'customer.login_page.create_account' | t }}</a>
          </div>
        {%- endform -%}

        {%- if shop.checkout.guest_login -%}
          <div class="fc-sep"></div>
          {%- form 'guest_login' -%}
            <button type="submit" class="fc-btn fc-btn--ghost">
              {{ 'customer.login_page.guest_continue' | t }}
            </button>
          {%- endform -%}
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-login.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_shop_login_button",
      "label": "t:sections.main-login.shop_login_button.enable",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
