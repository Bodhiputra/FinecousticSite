{%- style -%}

/* ── POLICY CONTENT ── */
.fc-policy-wrap {
  width: 100%;
  max-width: 780px;
  margin: 0 auto;
  padding: 0 var(--fc-page-gutter-sm, clamp(12px, 3vw, 40px)) 0;
  box-sizing: border-box;
}

/* Title lives in the carousel — hide duplicate Shopify policy h1s */
.fc-policy-panel > h1:first-child {
  display: none;
}

/* Same top spacing for every policy (h2/p/etc. first blocks) */
.fc-policy-panel.fc-pol-active > :first-child {
  margin-top: 0 !important;
}

.fc-policy-panel { display: none; }
.fc-policy-panel.fc-pol-active {
  display: block;
  animation: fc-pol-in 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
}
@keyframes fc-pol-in {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Prose */
.fc-policy-panel h1,
.fc-policy-panel h2,
.fc-policy-panel h3,
.fc-policy-panel h4 {
  font-family: var(--fc-font);
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.02em;
  margin: 40px 0 12px;
  line-height: 1.2;
}
.fc-policy-panel h1 { font-size: clamp(28px, 4vw, 42px); margin-top: 0; }
.fc-policy-panel h2 { font-size: clamp(20px, 2.5vw, 28px); }
.fc-policy-panel h3 { font-size: clamp(16px, 2vw, 20px); color: rgba(255,255,255,0.85); }

.fc-policy-panel p {
  font-family: var(--fc-font);
  font-size: clamp(14px, 1.2vw, 16px);
  color: rgba(255,255,255,0.65);
  line-height: 1.75;
  margin-bottom: 20px;
  letter-spacing: -0.01em;
}
.fc-policy-panel ul,
.fc-policy-panel ol {
  font-family: var(--fc-font);
  font-size: clamp(14px, 1.2vw, 16px);
  color: rgba(255,255,255,0.65);
  line-height: 1.75;
  margin-bottom: 20px;
  padding-left: 22px;
}
.fc-policy-panel li { margin-bottom: 8px; }
.fc-policy-panel a {
  color: var(--fc-yellow);
  text-decoration-color: rgba(255,211,0,0.4);
  text-underline-offset: 3px;
  transition: text-decoration-color 0.2s;
}
.fc-policy-panel a:hover { text-decoration-color: var(--fc-yellow); }
.fc-policy-panel strong { color: rgba(255,255,255,0.9); }
.fc-policy-panel hr {
  border: none;
  border-top: 1px solid rgba(255,255,255,0.08);
  margin: 40px 0;
}

{%- endstyle -%}

{%- render 'fc-title-carousel',
  id: 'fc-policies',
  labels: 'Privacy Policy|Shipping Policy|Return & Refund Policy|Terms & Conditions',
  active_index: 0
-%}

<div class="fc-page-swipe-zone fc-policy-wrap" id="fc-policy-wrap">

  <div class="fc-policy-panel" id="fc-pol-privacy" data-policy="privacy-policy">
    {%- if shop.privacy_policy.body != blank -%}
      {{ shop.privacy_policy.body }}
    {%- else -%}
      <h1>Privacy Policy</h1>
      <p>No privacy policy has been configured yet.</p>
    {%- endif -%}
  </div>

  <div class="fc-policy-panel" id="fc-pol-shipping" data-policy="shipping-policy">
    {%- if shop.shipping_policy.body != blank -%}
      {{ shop.shipping_policy.body }}
    {%- else -%}
      <p>No shipping policy has been configured yet.</p>
    {%- endif -%}
  </div>

  <div class="fc-policy-panel" id="fc-pol-refund" data-policy="refund-policy">
    {%- if shop.refund_policy.body != blank -%}
      {{ shop.refund_policy.body }}
    {%- else -%}
      <p>No refund policy has been configured yet.</p>
    {%- endif -%}
  </div>

  <div class="fc-policy-panel" id="fc-pol-terms" data-policy="terms-and-conditions">
    {%- if shop.terms_of_service.body != blank -%}
      {{ shop.terms_of_service.body }}
    {%- else -%}
      <h1>Terms &amp; Conditions</h1>
      <p>No terms of service has been configured yet.</p>
    {%- endif -%}
  </div>

</div>

<script>
(function () {

  const POLICIES = [
    { key: 'privacy-policy',       id: 'fc-pol-privacy'  },
    { key: 'shipping-policy',      id: 'fc-pol-shipping' },
    { key: 'refund-policy',        id: 'fc-pol-refund'   },
    { key: 'terms-and-conditions', id: 'fc-pol-terms'    },
  ];

  function applyPolicy(key) {
    document.querySelectorAll('.fc-policy-panel').forEach(panel => {
      panel.classList.remove('fc-pol-active');
      if (panel.dataset.policy === key) panel.classList.add('fc-pol-active');
    });
    const url = new URL(window.location.href);
    if (key === 'privacy-policy') {
      url.searchParams.delete('policy');
    } else {
      url.searchParams.set('policy', key);
    }
    history.pushState(null, '', url.toString());
  }

  function initCarousel() {
    if (!document.getElementById('fc-policies-header') || !window.FcTitleCarousel) return;
    window.FcTitleCarousel({
      id: 'fc-policies',
      extraSwipeId: 'fc-policy-wrap',
      swipeThreshold: 40,
      extraSwipeThreshold: 72,
      extraSwipeHorizontalRatio: 2.25,
      N: POLICIES.length,
      onSlide: function (logIdx) { applyPolicy(POLICIES[logIdx].key); },
      getInitialIdx: function () {
        var urlPolicy = new URLSearchParams(window.location.search).get('policy');
        var idx = urlPolicy ? POLICIES.findIndex(function (p) { return p.key === urlPolicy; }) : -1;
        return idx >= 0 ? idx : 0;
      }
    }).init();
  }

  function init() {
    if (!document.getElementById('fc-policies-header')) return;
    initCarousel();
  }

  init();
  document.addEventListener('shopify:section:load', function (evt) {
    if (!evt.target.querySelector || !evt.target.querySelector('#fc-policies-header')) return;
    init();
  });

  (function titleCaseTerms() {
    const panel = document.getElementById('fc-pol-terms');
    if (!panel) return;
    panel.querySelectorAll('h1, h2, h3, h4').forEach(el => {
      el.textContent = el.textContent.replace(/\S+/g, w =>
        w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()
      );
    });
  })();

})();
</script>

{% schema %}
{
  "name": "Policies",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Policies"
    }
  ]
}
{% endschema %}
