{%- liquid
  if section.settings.hero_image != blank
    assign hero_img = section.settings.hero_image
    assign hero_is_asset = false
  else
    assign hero_is_asset = true
  endif

  if section.settings.hero_image_mobile != blank
    assign hero_img_mobile = section.settings.hero_image_mobile
  elsif hero_is_asset == false
    assign hero_img_mobile = hero_img
  endif
-%}

<section class="website-hero" id="website-hero-{{ section.id }}">
  <picture class="website-hero__picture">
    {%- if hero_is_asset -%}
      <source
        media="(min-width: 750px)"
        srcset="{{ 'HeroSectionFinal.webp' | asset_url }}"
      >
      <img
        class="website-hero__img"
        src="{{ 'HeroSectionFinal-Mobile.webp' | asset_url }}"
        alt="{{ section.settings.image_alt | escape }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      <source
        media="(min-width: 750px)"
        srcset="
          {{ hero_img | image_url: width: 1100 }} 1100w,
          {{ hero_img | image_url: width: 1500 }} 1500w,
          {{ hero_img | image_url: width: 2000 }} 2000w,
          {{ hero_img | image_url: width: 2560 }} 2560w
        "
        sizes="100vw"
      >
      {{- hero_img_mobile | image_url: width: 1100 | image_tag:
        class: 'website-hero__img',
        loading: 'eager',
        fetchpriority: 'high',
        widths: '375, 550, 750, 1100',
        sizes: '100vw',
        alt: section.settings.image_alt
      -}}
    {%- endif -%}
  </picture>

  {%- if section.settings.show_overlay -%}
    <div class="website-hero__overlay" aria-hidden="true"></div>
  {%- endif -%}

  {%- if section.settings.heading != blank or section.settings.button_label != blank -%}
    <div class="website-hero__content">
      {%- if section.settings.heading != blank -%}
        <h1 class="website-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <a href="{{ section.settings.button_link }}" class="website-hero__cta">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
.website-hero {
  position: relative;
  width: 100%;
  height: 100svh;
  min-height: 480px;
  overflow: hidden;
  background: #0a0a0a;
}

@media screen and (min-width: 750px) {
  .website-hero {
    height: 72svh;
    min-height: 0;
    max-height: 560px;
  }
}

@media screen and (min-width: 990px) {
  .website-hero {
    height: 100vh;
    height: 100svh;
    max-height: none;
  }
}

.website-hero__picture {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.website-hero__picture .website-hero__img {
  position: absolute;
  inset: 0;
  display: block;
  width: 100%;
  height: 100%;
  max-width: none;
  object-fit: cover;
  object-position: center center;
}

.website-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0.15) 0%,
    rgba(0, 0, 0, 0.35) 55%,
    rgba(0, 0, 0, 0.75) 100%
  );
  pointer-events: none;
}

.website-hero__content {
  position: absolute;
  z-index: 1;
  inset: auto 0 0 0;
  padding: clamp(24px, 4vw, 48px) clamp(24px, 5vw, 64px);
}

.website-hero__heading {
  font-family: var(--fc-font, inherit);
  font-size: clamp(28px, 4.5vw, 64px);
  font-weight: 700;
  color: #fff;
  letter-spacing: -0.02em;
  line-height: 0.95;
  margin: 0 0 20px;
  max-width: min(900px, 85%);
}

.website-hero__cta {
  display: inline-block;
  font-family: var(--fc-font, inherit);
  font-size: clamp(14px, 1.5vw, 18px);
  font-weight: 700;
  letter-spacing: -0.01em;
  color: #121212;
  background: var(--fc-yellow, #ffd300);
  padding: 12px 28px;
  text-decoration: none;
  transition: opacity 0.2s ease;
}

.website-hero__cta:hover {
  opacity: 0.9;
}
{% endstylesheet %}

{% schema %}
{
  "name": "Website Hero",
  "tag": "section",
  "class": "section-website-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image (desktop)",
      "info": "Leave empty to use HeroSectionFinal.webp from theme assets."
    },
    {
      "type": "image_picker",
      "id": "hero_image_mobile",
      "label": "Hero image (mobile)",
      "info": "Leave empty to use HeroSectionFinal-Mobile.webp from theme assets."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Finecoustic"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show bottom gradient overlay",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Website Hero"
    }
  ]
}
{% endschema %}
