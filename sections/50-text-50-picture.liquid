<!-- sections/text-image-split.liquid -->
<section class="text-image-split">
  <div class="text-image-container {% if section.settings.reverse %}reverse{% endif %}">

    <!-- Text Column -->
    <div class="text-column">
      {% if section.settings.eyebrow != blank %}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.title != blank %}
        <h2 class="image-section-title">{{ section.settings.title }}</h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <div class="image-section-description">
          {{ section.settings.description }}
        </div>
      {% endif %}

      <!-- Features -->
      {% assign has_features = false %}
{% for i in (1..4) %}
  {% assign f_text_key = "feature_" | append: i | append: "_text" %}
  {% assign f_text = section.settings[f_text_key] %}
  {% if f_text and f_text != '' and f_text != blank %}
    {% assign has_features = true %}
  {% endif %}
{% endfor %}

{% if has_features %}
  <div class="features">
    {% for i in (1..4) %}
      {% assign f_text_key = "feature_" | append: i | append: "_text" %}
      {% assign f_icon_key = "feature_" | append: i | append: "_icon" %}
      {% assign f_text = section.settings[f_text_key] %}
      {% assign f_icon = section.settings[f_icon_key] %}

      {% if f_text and f_text != '' and f_text != blank %}
        <div class="feature">
          {% if f_icon != blank %}
            <img src="{{ f_icon | image_url: width: 32 }}" alt="{{ f_text }}">
          {% endif %}
          <span>{{ f_text }}</span>
        </div>
      {% endif %}
    {% endfor %}
  </div>
{% endif %}


      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" class="cta-button">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>

    <!-- Image Column -->
    <div class="image-column">
      {% if section.settings.image != blank %}
        <div class="image-wrapper">
          <img 
            src="{{ section.settings.image | image_url: width: 1200 }}" 
            alt="{{ section.settings.title | escape }}" 
          >
          {% if section.settings.badge != blank %}
            <div class="image-badge">{{ section.settings.badge }}</div>
          {% endif %}
        </div>
      {% endif %}
    </div>

  </div>
</section>

<style>
.text-image-split {
  background: #000000;
  padding: 40px 0;
  position: relative;
}

.text-image-container {
  display: flex;
  align-items: stretch; /* Make columns same height */
  justify-content: space-between;
  gap: 80px;
  padding: 0 50px;
  margin: 0 auto;
  flex-wrap: nowrap;
  max-width: 90vw;
}

.text-image-container.reverse {
  flex-direction: row-reverse;
}

.text-column {
  flex: 1 1 40%;
  display: flex;
  flex-direction: column;
  justify-content: center; /* Vertically center content */
  text-align: left; /* Default, overridden below */
}

.image-column {
  flex: 1 1 60%;
  position: relative;
  display: flex;
  align-items: center; /* Optional: center image vertically if smaller than container */
}

.image-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: 12px;
  width: 100%;
  display: flex;
}

.image-column img {
  width: 100%;
  height: auto;
  object-fit: cover;
  border-radius: 12px;
}

.image-badge {
  position: absolute;
  top: 15px;
  left: 15px;
  background: var(--fc-yellow);
  border: 2px solid black;
  padding: 6px 12px;
  font-size: 14px;
  font-weight: 700;
  border-radius: 6px;
  box-shadow: 0 2px 5px rgba(0,0,0,0.1);
  color: black;
}

.eyebrow {
  text-transform: uppercase;
  font-size: 12px;
  font-weight: 700;
  color: var(--fc-yellow);
  margin: 0;
  letter-spacing: -0.01em;
  margin-bottom: 5px;
}

.image-section-title {
  font-size: 32px;
  font-weight: 800;
  color: #ffffff;
  margin: 0;
  line-height: 1.3;
  margin-bottom: 15px;
}

.image-section-description p {
  font-size: 18px;
  color: rgba(255,255,255,0.6);
  margin: 0;
  font-weight: 500;
  line-height: 1.6;
  margin-bottom: 20px;
}

.features {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
  margin: 0;
  margin-bottom: 25px;
}

.feature {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 16px;
  color: rgba(255,255,255,0.6);
  transition: transform 0.2s ease;
}

.feature img {
  display: block;
  width: 24px;
  height: 24px;
}

.feature:hover {
  transform: translateY(-2px);
}

.cta-button {
  display: inline-block;
  background: transparent;
  border: 2px solid #ffffff;
  color: #ffffff;
  padding: 2.5px 25px;
  border-radius: 24px;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.3s ease;
  box-shadow: 0 3px 5px rgba(0,0,0,0.15);
  font-size: 16px;
  width: max-content;
}

.cta-button:hover {
  background: var(--fc-yellow);
  color: black;
  transform: translateY(-2px);
}

.text-image-container:not(.reverse) .features {
  justify-content: flex-end;
  text-align: right;
}

/* Reverse: image left, text left → features left */
.text-image-container.reverse .features {
  justify-content: flex-start;
  text-align: left;
}

/* --- Text Alignment Rules --- */

/* Default: image right, text aligns right */
.text-image-container:not(.reverse) .text-column {
  text-align: right;
  align-items: flex-end;
}

/* Reverse: image left, text aligns left */
.text-image-container.reverse .text-column {
  text-align: left;
  align-items: flex-start;
}

/* --- Responsive Adjustments --- */

/* Start stacking at 1200px and below */
@media (max-width: 1200px) {
  .text-image-container {
    flex-direction: column-reverse;
    gap: 30px;
    padding: 0 50px;
  }
  .text-image-container.reverse {
    flex-direction: column;
  }
  .text-column,
  .image-column {
    flex: 1 1 100%;
  }
  .image-section-title {
    font-size: 26px;
  }
  .image-section-description {
    font-size: 15px;
  }

  .text-image-container.reverse {
    flex-direction: column-reverse;
  }

  .text-image-container:not(.reverse) .text-column {
  text-align: left !important;
  align-items: flex-start !important;
}
}

/* Extra small screens below 768px */
@media (max-width: 768px) {
  .text-image-container {
    gap: 20px;
    padding: 0 15px;
  }
  .image-section-title {
    font-size: 22px;
  }

  .image-section-description p{
    font-size: 16px;
  }

  .text-image-container:not(.reverse) .features {
  align-items: flex-start !important;
  text-align: left;
  justify-content: start;
  }
}

@media (max-width: 749.5px) {

  .text-image-container:not(.reverse) .features {
  align-items: flex-start !important;
  text-align: left;
  justify-content: start;
  }

  .text-image-split{
  padding-bottom: 10px;
  }
}


</style>

{% schema %}
{
  "name": "Text + Image Features",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow Text (Small Heading)", "default": "New Collection" },
    { "type": "text", "id": "title", "label": "Title", "default": "Your Section Title" },
    { "type": "richtext", "id": "description", "label": "Description", "default": "<p>Write your section description here.</p>" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "badge", "label": "Image Badge", "default": "Best Seller" },
    { "type": "text", "id": "button_label", "label": "Button Label", "default": "Shop Now" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "checkbox", "id": "reverse", "label": "Reverse Layout (Image Left, Text Right)", "default": false },
    
    { "type": "text", "id": "feature_1_text", "label": "Feature 1 Text", "default": "Free Shipping" },
    { "type": "image_picker", "id": "feature_1_icon", "label": "Feature 1 Icon" },
    { "type": "text", "id": "feature_2_text", "label": "Feature 2 Text", "default": "Eco-Friendly Materials" },
    { "type": "image_picker", "id": "feature_2_icon", "label": "Feature 2 Icon" },
    { "type": "text", "id": "feature_3_text", "label": "Feature 3 Text", "default": "Fast Delivery" },
    { "type": "image_picker", "id": "feature_3_icon", "label": "Feature 3 Icon" },
    { "type": "text", "id": "feature_4_text", "label": "Feature 4 Text", "default": "24/7 Support" },
    { "type": "image_picker", "id": "feature_4_icon", "label": "Feature 4 Icon" }
  ],
  "presets": [
    { "name": "Text + Image Split with Features", "category": "Custom" }
  ]
}
{% endschema %}