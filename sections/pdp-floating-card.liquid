{%- assign variant = product.selected_or_first_available_variant -%}
{%- assign thumb = product.featured_image -%}
{%- assign is_available = variant.available -%}

<!-- Desktop floating card -->
<div class="pdp-fc" id="pdp-fc-{{ section.id }}">
  <div class="pdp-fc__img-wrap">
    {%- if thumb != blank -%}
      {{- thumb | image_url: width: 200 | image_tag: class: 'pdp-fc__img', loading: 'lazy' -}}
    {%- endif -%}
  </div>
  {%- if section.settings.spec_1 != blank or section.settings.spec_2 != blank or section.settings.spec_3 != blank -%}
    <ul class="pdp-fc__specs">
      {%- if section.settings.spec_1 != blank -%}<li>{{ section.settings.spec_1 }}</li>{%- endif -%}
      {%- if section.settings.spec_2 != blank -%}<li>{{ section.settings.spec_2 }}</li>{%- endif -%}
      {%- if section.settings.spec_3 != blank -%}<li>{{ section.settings.spec_3 }}</li>{%- endif -%}
    </ul>
  {%- endif -%}

  {%- render 'fc-price-tag',
    variant_id: variant.id,
    price: variant.price,
    price_varies: false,
    title: product.title,
    available: is_available,
    show_barcode: true,
    name_class: 'pdp-tag__name',
    tag_class: 'pdp-fc__tag',
    product_url: product.url
  -%}
</div>

<!-- Mobile bottom bar -->
<div class="pdp-fc-bar" id="pdp-fc-bar-{{ section.id }}">
  <div class="pdp-fc-bar__info">
    {%- if thumb != blank -%}
      {{- thumb | image_url: width: 80 | image_tag: class: 'pdp-fc-bar__img', loading: 'lazy' -}}
    {%- endif -%}
    <span class="pdp-fc-bar__name">{{ product.title }}</span>
  </div>
  {%- render 'fc-price-tag',
    variant_id: variant.id,
    price: variant.price,
    price_varies: false,
    title: product.title,
    available: is_available,
    show_barcode: false,
    name_class: 'pdp-tag__name--bar',
    tag_class: 'pdp-fc-bar__tag',
    product_url: product.url
  -%}
</div>

{% stylesheet %}
/* ── Desktop floating card ── */
.pdp-fc {
  position: fixed;
  right: 32px;
  top: 50%;
  transform: translateY(-50%);
  z-index: 900;
  width: 220px;
  background: rgba(0,0,0,0.92);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 12px;
  padding: 20px;
  backdrop-filter: blur(16px);
  display: flex;
  flex-direction: column;
  gap: 14px;
  align-items: flex-start;
}
@media (max-width: 749px) { .pdp-fc { display: none; } }

.pdp-fc__img-wrap {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 8px;
  overflow: hidden;
  background: rgba(255,255,255,0.04);
}
.pdp-fc__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.pdp-fc__specs {
  list-style: none;
  margin: 0;
  padding: 10px 0;
  display: flex;
  flex-direction: column;
  gap: 5px;
  width: 100%;
  border-top: 1px solid rgba(255,255,255,0.08);
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.pdp-fc__specs li {
  font-family: var(--fc-font);
  font-size: 11px;
  color: rgba(255,255,255,0.6);
  letter-spacing: -0.01em;
  padding-left: 14px;
  position: relative;
}
.pdp-fc__specs li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: var(--fc-yellow);
  font-size: 10px;
}

/* tag inside the floating card: reset the auto-margin */
.pdp-fc .fc-card__tag,
.pdp-fc .fc-tag-oos-wrap { margin: 0; }

/* name width overrides for the floating card context */
.pdp-tag__name { width: 120px; }
.pdp-tag__name--bar { width: 80px; }

/* ── Mobile bottom bar ── */
.pdp-fc-bar {
  display: none;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 900;
  background: rgba(0,0,0,0.96);
  border-top: 1px solid rgba(255,255,255,0.1);
  backdrop-filter: blur(16px);
  padding: 10px 20px;
  align-items: center;
  gap: 12px;
}
@media (max-width: 749px) { .pdp-fc-bar { display: flex; } }

.pdp-fc-bar__info {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
  min-width: 0;
}
.pdp-fc-bar__img {
  width: 40px;
  height: 40px;
  border-radius: 6px;
  object-fit: cover;
  flex-shrink: 0;
  display: block;
}
.pdp-fc-bar__name {
  font-family: var(--fc-font);
  font-size: 11px;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.07em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.pdp-fc-bar__tag { flex-shrink: 0; margin: 0; }
.pdp-fc-bar .fc-tag-oos-wrap { margin: 0; }
{% endstylesheet %}

<script>
(function() {
  var sId = {{ section.id | json }};
  var variantId = {{ variant.id | json }};

  async function addToCart(varId, qty) {
    try {
      await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: varId, quantity: qty })
      });
      var cartTrigger = document.getElementById('cart-icon-bubble');
      if (cartTrigger) cartTrigger.click();
    } catch(e) {}
  }

  function wireTag(tag) {
    if (!tag || !window.fcWirePriceTag) return;
    window.fcWirePriceTag(tag, {
      getVariantId: function () { return variantId; },
      onAdd: addToCart
    });
  }

  wireTag(document.querySelector('#pdp-fc-' + sId + ' .pdp-fc__tag'));
  wireTag(document.querySelector('#pdp-fc-bar-' + sId + ' .pdp-fc-bar__tag'));
})();
</script>

{% schema %}
{
  "name": "PDP Floating Card",
  "settings": [
    {
      "type": "text",
      "id": "spec_1",
      "label": "Key spec 1"
    },
    {
      "type": "text",
      "id": "spec_2",
      "label": "Key spec 2"
    },
    {
      "type": "text",
      "id": "spec_3",
      "label": "Key spec 3"
    }
  ],
  "presets": [
    {
      "name": "PDP Floating Card"
    }
  ]
}
{% endschema %}
