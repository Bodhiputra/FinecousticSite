<div class="fc-shop-page fc-dl-page{% if section.settings.custom_class != blank %} {{ section.settings.custom_class }}{% endif %}">

  {%- render 'fc-title-carousel',
    id: 'fc-dl',
    labels: 'All Products|Earphones|Speakers|Microphones',
    active_index: 0
  -%}

  <div class="fc-page-swipe-zone fc-shop-swipe-zone" id="fc-dl-swipe-zone">
    <div class="fc-grid" id="fc-dl-grid" data-cols="5">
      {%- assign dl_category = '' -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'Heading' -%}
            {%- assign dl_category = block.settings.heading_text | downcase -%}
            {%- if dl_category contains 'earbud' -%}
              {%- assign dl_category = 'earphones' -%}
            {%- elsif dl_category contains 'mic' -%}
              {%- assign dl_category = 'microphones' -%}
            {%- elsif dl_category contains 'speaker' -%}
              {%- assign dl_category = 'speakers' -%}
            {%- endif -%}
          {%- when 'Text' -%}
            {%- assign dl_product = all_products[block.settings.product_handle] -%}
            <div class="fc-card" data-category="{{ dl_category }}" {{ block.shopify_attributes }}>
              <div class="fc-card__image">
                {%- if block.settings.product_handle != blank and dl_product != blank and dl_product.featured_image -%}
                  {{ dl_product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'fc-card__img fc-img-active', alt: block.settings.title }}
                {%- elsif block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'fc-card__img fc-img-active', alt: block.settings.title | escape }}
                {%- endif -%}
              </div>

              {%- if block.settings.title != blank -%}
                <p class="fc-dl-card-name">{{ block.settings.title }}</p>
              {%- endif -%}
              {%- if block.settings.download_url != blank -%}
                {%- render 'fc-guide-tag',
                  download_url: block.settings.download_url,
                  title: block.settings.title
                -%}
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <p class="fc-category-soon" id="fc-dl-soon" hidden>Soon.</p>
  </div>

</div>

<script>
(function () {

  const FILTERS = [
    { key: 'all',         label: 'All Products' },
    { key: 'earphones',   label: 'Earphones' },
    { key: 'speakers',    label: 'Speakers' },
    { key: 'microphones', label: 'Microphones' },
  ];

  function updateGridColumns(visibleCount) {
    const grid = document.getElementById('fc-dl-grid');
    if (!grid) return;
    const maxCols = parseInt(grid.dataset.cols, 10) || 5;
    const cols = Math.max(1, Math.min(visibleCount, maxCols));
    grid.style.setProperty('--fc-visible-cols', String(cols));
  }

  function applyFilter(filter) {
    let visIdx = 0;
    let visibleCount = 0;
    document.querySelectorAll('#fc-dl-grid .fc-card').forEach(card => {
      card.classList.remove('fc-card-appear');
      const show = filter === 'all' || card.dataset.category === filter;
      if (!show) {
        card.classList.add('fc-hidden');
      } else {
        visibleCount++;
        card.classList.remove('fc-hidden');
        const delay = visIdx * 90;
        visIdx++;
        requestAnimationFrame(() => {
          card.style.animationDelay = delay + 'ms';
          card.classList.add('fc-card-appear');
        });
      }
    });
    const soonEl = document.getElementById('fc-dl-soon');
    const zone = document.getElementById('fc-dl-swipe-zone');
    const showSoon = filter === 'speakers' && visibleCount === 0;
    if (soonEl) soonEl.hidden = !showSoon;
    if (zone) zone.classList.toggle('fc-shop-swipe-zone--soon', showSoon);
    updateGridColumns(visibleCount);
  }

  function fcFitNames() {
    document.querySelectorAll('#fc-dl-grid .fc-dl-card-name').forEach(el => {
      el.style.fontSize = '';
      let size = parseFloat(getComputedStyle(el).fontSize);
      while (el.scrollWidth > el.offsetWidth && size > 7) {
        size -= 0.5;
        el.style.fontSize = size + 'px';
      }
    });
  }

  function initCarousel() {
    if (!document.getElementById('fc-dl-header') || !window.FcTitleCarousel) return;
    window.FcTitleCarousel({
      id: 'fc-dl',
      extraSwipeId: 'fc-dl-swipe-zone',
      N: FILTERS.length,
      onSlide: function (logIdx) { applyFilter(FILTERS[logIdx].key); },
      getInitialIdx: function () { return 0; }
    }).init();
  }

  function init() {
    if (!document.getElementById('fc-dl-header')) return;
    initCarousel();
    applyFilter('all');
    fcFitNames();
  }

  init();
  document.addEventListener('shopify:section:load', function (evt) {
    if (!evt.target.querySelector || !evt.target.querySelector('#fc-dl-header')) return;
    init();
  });

  let fcFitTimer;
  window.addEventListener('resize', () => {
    clearTimeout(fcFitTimer);
    fcFitTimer = setTimeout(fcFitNames, 120);
  });

})();
</script>

{% schema %}
{
  "name": "Custom Image with Text",
  "settings": [
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    }
  ],
  "blocks": [
    {
      "type": "Text",
      "name": "Add Product",
      "settings": [
        { "type": "text",         "id": "product_handle", "label": "Product Handle (e.g. groove-anc-ft20)" },
        { "type": "text",         "id": "title",          "label": "Product Display Name" },
        { "type": "text",         "id": "download_url",   "label": "Quick Start Guide PDF URL" },
        { "type": "image_picker", "id": "image",          "label": "Fallback Image (if product handle is blank)" }
      ]
    },
    {
      "type": "Heading",
      "name": "Add Category",
      "settings": [
        { "type": "text", "id": "heading_text", "label": "Category (e.g. Earbuds, Microphones)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Image with Text (download)"
    }
  ]
}
{% endschema %}
