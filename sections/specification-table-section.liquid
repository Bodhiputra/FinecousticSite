{% schema %}
{
  "name": "Specification Table",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Table Title",
      "default": "Specs"
    },
    {
      "type": "textarea",
      "id": "rows",
      "label": "Table Rows (format: Type - Value, one per line)",
      "default": "Drivers | 4.6 mm Drivers\nPlaytime | 9H/45H\nSound | Balanced Sound\nWater Resistance | IPX4\nBluetooth Version | 5.4\nActive Noise Cancellation | Smart ANC Engineered for Sleep\nFast Charging | No\nCalls | Single Mic\nMultipoint Connection | No\nWeight | 3g\nSpecial Features | 3-Stage Snore Masking System\nDesign | In-Ear\nControl | Tap Control"
    }
  ],
  "presets": [
    {
      "name": "Specification Table",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<section class="spec-table">
  <div class="spec-table-container" style="width: 100%;">
    {% if section.settings.title != blank %}
      <h2 class="spec-title">{{ section.settings.title }}</h2>
    {% endif %}

    <table class="spec-table-wrapper">
      <tbody>
        {% assign rows = section.settings.rows | newline_to_br | split: '<br />' %}
        {% for row in rows %}
          {% assign parts = row | split: ' | ' %}
          {% assign mod_index = forloop.index0 | modulo: 2 %}
          {% if mod_index == 0 %}
            <tr>
          {% endif %}
              <td class="spec-type">{{ parts[0] }}</td>
              <td class="spec-value">{{ parts[1] }}</td>
          {% if mod_index == 1 or forloop.last %}
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

{% stylesheet %}
.spec-table-container {
    max-width: 90vw;
    padding: 0 6rem;
}

.spec-table {
  padding: 0 20px;
  text-align: center;
  background-color: white;
  display: flex;
  justify-content: center;
  align-items: center;
}
.spec-title {
  font-size: 40px;
  font-weight: 800;
  margin-bottom: 24px;
}
.spec-table-wrapper {
  width: 100%; /* full width */
  border-collapse: collapse;
  background: white;
  overflow: hidden;
  border: 1px solid #afafaf; /* add border around entire table */
}

.spec-table-wrapper td {
  border: 1px solid #afafaf; /* keep cell borders */
  padding: 14px 18px;
  text-align: left;
  vertical-align: middle;
  font-size: 17.5px;
}

.spec-type {
  font-weight: 500;
  color: #808080;
  width: 25%;
}
.spec-value {
  font-weight: 500;
  color: black;
  width: 25%;
}

@media (max-width: 990px) {
    .spec-table-container {
    max-width: 88vw;
}

.spec-table-wrapper td {
  padding: 7px 9px;
}
}

@media (max-width: 768px) {
  .spec-table-wrapper {
    width: 100%;
    border-collapse: collapse;
  }

  .spec-table-container {
    max-width: 100vw;
    padding: 0 4rem !important;
  }

  .spec-table-wrapper tr {
    display: flex;
    flex-wrap: wrap; /* wrap if screen is narrow */
    font-size: 16px;
  }

  .spec-table-wrapper td {
    flex: 1 1 50%; /* two cells per row */
    padding: 8px 10px;
    border: 1px solid #ddd;
    box-sizing: border-box;
    font-size: 16px;
  }

  .spec-type {
    font-weight: 600;
  }

  .spec-value {
    font-weight: 500;
  }
}

@media (max-width: 720px) {
    .spec-table-container {
    padding: 0 3.5rem !important;
    }
}

@media (max-width: 600px) {
    .spec-table-container {
    padding: 0 2.5rem !important;
    }
}

@media (max-width: 480px) {
    .spec-table-container {
    padding: 0 1.5rem !important;
    }
}

{% endstylesheet %}
